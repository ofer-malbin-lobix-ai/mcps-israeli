{
  "name": "kolzchut-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Kolzchut (All-Rights) - Israel's rights and entitlements knowledge base",
  "type": "module",
  "bin": {
    "kolzchut-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "kolzchut",
    "israel",
    "rights",
    "entitlements",
    "olim",
    "immigration"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
