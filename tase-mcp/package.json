{
  "name": "tase-mcp",
  "version": "1.0.0",
  "description": "MCP server for Tel Aviv Stock Exchange (TASE) market data",
  "type": "module",
  "bin": {
    "tase-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "dev": "tsx src/index.ts",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "tase",
    "tel-aviv-stock-exchange",
    "israel",
    "stocks",
    "finance"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/skills-il/tase-mcp"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
