{
  "name": "israel-vehicles-mcp",
  "version": "1.0.0",
  "description": "MCP server for Israeli Vehicle Registry data from the Ministry of Transport via data.gov.il",
  "type": "module",
  "bin": {
    "israel-vehicles-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "prepare": "npm run build",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "israel",
    "vehicles",
    "car",
    "license-plate",
    "data-gov-il"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.28.0",
    "express": "^4.21.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
